{
  "name": "@kast-cms/plugin-sdk",
  "version": "0.1.0",
  "description": "SDK for building Kast CMS plugins",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "kast",
    "cms",
    "plugin",
    "sdk",
    "typescript",
    "headless-cms"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kast-cms/kast.git",
    "directory": "packages/plugin-sdk"
  },
  "homepage": "https://docs.kast.dev",
  "engines": {
    "node": ">=18"
  }
}
