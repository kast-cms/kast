    "globals": "^17.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.3.0",
    "prettier-plugin-organize-imports": "^4.1.0",
    "turbo": "^2.9.8",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.1"
