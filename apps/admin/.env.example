# Kast Admin — Environment Variables
# Copy to .env.local and fill in values for local development

# Public (exposed to browser via Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_BASE_PATH=/admin

# Server-only (not exposed to browser)
# Defaults to NEXT_PUBLIC_API_URL if unset — override for Docker/K8s internal networking
INTERNAL_API_URL=http://localhost:3000

# Cookie name for the HttpOnly refresh token
REFRESH_TOKEN_COOKIE_NAME=kast_rt

# Node environment
NODE_ENV=development
