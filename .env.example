# ──────────────────────────────────────────
# Kast CMS API — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL 16)
DATABASE_URL=postgresql://kast:kast_secret@localhost:5432/kast_db

# Redis 7
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT (minimum 32-character secret)
JWT_SECRET=change_me_to_a_very_long_random_secret_min32
JWT_EXPIRES_IN=15m

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# Storage provider: local | s3 | r2 | gcs
STORAGE_PROVIDER=local
STORAGE_LOCAL_DIR=/tmp/kast-uploads
STORAGE_LOCAL_URL=http://localhost:3000/uploads

# AWS S3 (only required when STORAGE_PROVIDER=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# Upload limits
UPLOAD_MAX_FILE_SIZE_MB=10
UPLOAD_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf
